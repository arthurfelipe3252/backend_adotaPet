FROM node:22-alpine
ARG SERVICE_NAME
WORKDIR /app
COPY . .
RUN npm install --prefix services/${SERVICE_NAME} --fetch-retries=5 --fetch-retry-mintimeout=5000
RUN ln -s /app/services/${SERVICE_NAME}/node_modules /app/node_modules
RUN npm run build --prefix services/${SERVICE_NAME}
WORKDIR /app/services/${SERVICE_NAME}
CMD ["npm", "run", "start:prod"]
