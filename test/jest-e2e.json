{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "moduleNameMapper": {
    "^@shared/(.*)$": "<rootDir>/../src/shared/$1",
    "^@identity/(.*)$": "<rootDir>/../src/modules/identity/$1",
    "^@catalog/(.*)$": "<rootDir>/../src/modules/catalog/$1",
    "^@match/(.*)$": "<rootDir>/../src/modules/match/$1",
    "^@adoption/(.*)$": "<rootDir>/../src/modules/adoption/$1",
    "^@chat/(.*)$": "<rootDir>/../src/modules/chat/$1",
    "^@timeline/(.*)$": "<rootDir>/../src/modules/timeline/$1",
    "^@geo/(.*)$": "<rootDir>/../src/modules/geo/$1",
    "^@notifications/(.*)$": "<rootDir>/../src/modules/notifications/$1",
    "^@payments/(.*)$": "<rootDir>/../src/modules/payments/$1",
    "^@reports/(.*)$": "<rootDir>/../src/modules/reports/$1"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
