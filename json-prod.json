          {
            "name": "especie",
            "required": true,
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "porte",
            "required": true,
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "status",
            "required": true,
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "castrado",
            "required": true,
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "protetorId",
            "required": true,
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "" } },
        "tags": ["Pets"]
      },
      "post": {
        "operationId": "PetsController_create",
        "parameters": [],
        "responses": { "201": { "description": "" } },
        "tags": ["Pets"]
      }
    },
    "/api/v1/pets/{id}": {
      "get": {
        "operationId": "PetsController_findById",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "" } },
        "tags": ["Pets"]
      },
      "patch": {
        "operationId": "PetsController_update",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "" } },
        "tags": ["Pets"]
      },
      "delete": {
        "operationId": "PetsController_delete",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "204": { "description": "" } },
        "tags": ["Pets"]
      }
