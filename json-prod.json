{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/health": {
      "get": {
        "operationId": "HealthController_check",
        "parameters": [],
        "responses": { "200": { "description": "Aplicação em pé" } },
        "summary": "Liveness probe — usado pelo Docker/Easypanel",
        "tags": ["Health"]
      }
    },
    "/api/v1/pets": {
      "get": {
        "operationId": "PetsController_findAll",
